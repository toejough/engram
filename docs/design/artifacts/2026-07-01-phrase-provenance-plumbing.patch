 // plantNoteWithSidecar populates memFS with a note + matching sidecar.
+// plantAxisNote plants a note with a fixed vector compatible with axisEmbedder
+// (dims=3, modelID="fake@3") so cosine results are fully deterministic.
+func plantAxisNote(t *testing.T, memFS *inMemoryFS, vault, relPath, body string, vec []float32) {
+	t.Helper()
+
+	memFS.files[filepath.Join(vault, relPath)] = []byte(body)
+
+	sidecar := embed.Sidecar{
+		SchemaVersion:    embed.SidecarSchemaVersion,
+		EmbeddingModelID: "fake@3",
+		Dims:             3,
+		SituationVector:  vec,
+		BodyVector:       vec,
+		ContentHash:      embed.ContentHash([]byte(body)),
+	}
+
+	memFS.files[filepath.Join(vault, embed.SidecarPath(relPath))] = embed.MarshalSidecar(sidecar)
+}
