+// unionPhraseIndices returns the sorted union of two phrase-index slices.
+// Either slice may be nil (treated as empty). The result is always sorted
+// ascending so the payload carries a canonical, diffable representation.
+//
+// Aliasing note: the empty-input fast paths return the other slice directly
+// (sharing its backing array) rather than copying. Safe because every caller
+// only reads or reassigns the result — none appends into it in place. If a
+// future caller mutates the return value, drop these fast paths or clone.
+func unionPhraseIndices(a, b []int) []int {
+	if len(a) == 0 {
+		return b
+	}
+
+	if len(b) == 0 {
+		return a
+	}
+
+	seen := make(map[int]bool, len(a)+len(b))
+
+	for _, index := range a {
+		seen[index] = true
+	}
+
+	for _, index := range b {
+		seen[index] = true
+	}
+
+	result := make([]int, 0, len(seen))
+
+	for index := range seen {
+		result = append(result, index)
+	}
+
+	sort.Ints(result)
+
+	return result
+}
