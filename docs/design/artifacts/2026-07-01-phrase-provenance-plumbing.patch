+// TestQuery_PhraseMember_CarriesPhraseIndicesInPayload asserts that the rendered
+// payload carries, on each cluster member and item, the sorted union of phrase
+// indices that retrieved it.
+//
+// Setup:
+//
+//	axisEmbedder: "match"→{1,0,0}  "other"→{0,1,0}  default→{0,0,1}
+//	note A vector {1,0,0}: cosine≥floor for phrases 0,2 only → phrases:[0,2]
+//	note B vector {0,1,0}: cosine≥floor for phrase 1 only   → phrases:[1]
+func TestQuery_PhraseMember_CarriesPhraseIndicesInPayload(t *testing.T) {
+	t.Parallel()
+
+	g := NewWithT(t)
+
+	vault := t.TempDir()
+	memFS := newInMemoryFS()
+
+	plantAxisNote(t, memFS, vault, "1.a.md", "---\ntype: fact\n---\nbody A\n", []float32{1, 0, 0})
+	plantAxisNote(t, memFS, vault, "2.b.md", "---\ntype: fact\n---\nbody B\n", []float32{0, 1, 0})
+
+	deps := cli.QueryDeps{
+		Scan: memFS.Scan,
+		Read: memFS.Read,
+		Embedder: axisEmbedder{axes: map[string][]float32{
+			"match": {1, 0, 0},
+			"other": {0, 1, 0},
+		}},
+	}
+
+	var out bytes.Buffer
+
+	err := cli.RunQuery(context.Background(),
+		cli.QueryArgs{
+			Phrases:   []string{"match query", "other topic", "match again"},
+			VaultPath: vault,
+		},
+		deps, &out)
+
+	g.Expect(err).NotTo(HaveOccurred())
+
+	if err != nil {
+		return
+	}
+
+	var parsed struct {
+		Items []struct {
+			Path    string `yaml:"path"`
+			Phrases []int  `yaml:"phrases"`
+		} `yaml:"items"`
+		Clusters []struct {
+			Members []struct {
+				Path    string `yaml:"path"`
+				Phrases []int  `yaml:"phrases"`
+			} `yaml:"members"`
+		} `yaml:"clusters"`
+	}
+
+	g.Expect(yaml.Unmarshal(out.Bytes(), &parsed)).NotTo(HaveOccurred())
+	g.Expect(parsed.Clusters).NotTo(BeEmpty(), "expected at least one cluster")
+
+	// Collect phrases per path from cluster members.
+	memberPhrases := map[string][]int{}
+
+	for _, cl := range parsed.Clusters {
+		for _, m := range cl.Members {
+			memberPhrases[m.Path] = m.Phrases
+		}
+	}
+
+	// Note A: matched by phrases 0 and 2 → sorted union [0, 2].
+	g.Expect(memberPhrases["1.a.md"]).To(Equal([]int{0, 2}),
+		"note A cluster member must carry phrases [0, 2]")
+
+	// Note B: matched by phrase 1 only → [1].
+	g.Expect(memberPhrases["2.b.md"]).To(Equal([]int{1}),
+		"note B cluster member must carry phrase [1]")
+
+	// Collect phrases per path from items[].
+	itemPhrases := map[string][]int{}
+
+	for _, item := range parsed.Items {
+		itemPhrases[item.Path] = item.Phrases
+	}
+
+	g.Expect(itemPhrases["1.a.md"]).To(Equal([]int{0, 2}),
+		"note A item must carry phrases [0, 2]")
+	g.Expect(itemPhrases["2.b.md"]).To(Equal([]int{1}),
+		"note B item must carry phrase [1]")
+}
